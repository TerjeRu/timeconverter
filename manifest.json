{
  "manifest_version": 3,
  "name": "Time Converter",
  "version": "1.0.0",
  "description": "Browser extension that converts displayed times to your local time.",
  "permissions": ["scripting", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["luxon.min.js", "contentScript.js"],
      "css": ["styles.css"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
