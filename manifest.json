{
  "manifest_version": 3,
  "name": "Time Converter",
  "version": "0.10",
  "description": "Browser extension that converts displayed times to your local time.",
  "permissions": ["scripting", "storage"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["luxon.min.js", "contentScript.js"],
      "css": ["styles.css"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
